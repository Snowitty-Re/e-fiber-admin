# =============================================================================
# .env.example —— 环境变量模板
# 复制为 .env 并填入真实值；.env 被忽略，禁止提交真实密钥。
# =============================================================================

# App
APP_ENV=development
APP_PORT=8080
APP_NAME=e-fiber-admin
LOG_LEVEL=debug

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=efa
POSTGRES_PASSWORD=efa_secret
POSTGRES_DB=efa
DATABASE_URL=postgres://efa:efa_secret@localhost:5432/efa?sslmode=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# MinIO / S3
MINIO_ROOT_USER=efa
MINIO_ROOT_PASSWORD=efa_secret
MINIO_ENDPOINT=localhost:9000
MINIO_USE_SSL=false
MINIO_BUCKET=efa-media
S3_ACCESS_KEY=efa
S3_SECRET_KEY=efa_secret

# JWT（access + refresh）
JWT_ACCESS_SECRET=change-me-to-a-strong-random-string
JWT_REFRESH_SECRET=change-me-to-a-different-strong-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# asynq
ASYNQ_CONCURRENCY=10
